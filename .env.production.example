# ============================================================
# Wrong Club — Production Environment Variables
# Set these in Vercel Dashboard → Project Settings → Environment Variables
# ============================================================

# App
NEXT_PUBLIC_APP_URL=https://wrongclub.com

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI — Caddie feature
ANTHROPIC_API_KEY=

# Stripe — payments
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email — Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=Wrong Club <noreply@wrongclub.com>

# Security (generate 32+ character random strings)
DATABASE_ENCRYPTION_KEY=
API_SIGNING_SECRET=
ANALYTICS_PASSWORD=

# Optional: Beta gate
SITE_PASSWORD=

# Optional: Background removal
POOF_BG_API_KEY=

# Optional: Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# CORS
ALLOWED_ORIGINS=https://wrongclub.com
